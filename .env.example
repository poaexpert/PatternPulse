# Server
PORT=3001
NODE_ENV=development

# Claude AI (for chart analysis - get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Pushover (https://pushover.net/)
PUSHOVER_USER_KEY=your_user_key_here
